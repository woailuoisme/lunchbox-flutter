        type: 'lunchbox',
        status: 'online',
        location: const DeviceLocation(
          latitude: 39.9840,
          longitude: 116.3070,
          address: '北京市海淀区中关村南大街5号',
          city: '北京',
        ),
        lastOnlineTime: DateTime.now(),
        productCount: 85,
        isFavorite: true,
      ),
      DeviceModel(
        id: 'device3',
        name: '大学城美食广场',
        type: 'lunchbox',
        status: 'offline',
        location: const DeviceLocation(
          latitude: 39.9635,
          longitude: 116.3584,
          address: '北京市海淀区学院路15号',
          city: '北京',
        ),
        lastOnlineTime: DateTime.now().subtract(const Duration(hours: 2)),
        productCount: 60,
        isFavorite: false,
      ),
      DeviceModel(
        id: 'device4',
        name: '上海陆家嘴金融中心',
        type: 'lunchbox',
        status: 'online',
        location: const DeviceLocation(
          latitude: 31.2304,
          longitude: 121.4737,
          address: '上海市浦东新区世纪大道100号',
          city: '上海',
        ),
        lastOnlineTime: DateTime.now(),
        productCount: 120,
        isFavorite: false,
      ),
    ];

    // 如果指定了城市，进行筛选
    if (city != null && city.isNotEmpty) {
      final filteredDevices = devices
          .where((device) => device.location.city == city)
          .toList();
      return ApiResponseModel.success(filteredDevices);
    }

    return ApiResponseModel.success(devices);
  }
