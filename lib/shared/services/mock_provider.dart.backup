  /// 根据产品ID获取产品详情
  Future<ApiResponseModel<ProductModel>> getProductById(
    String productId,
  ) async {
    await _delay();

    // 先获取所有产品
    final allProducts = await getProductsByDeviceId('any');
    if (!allProducts.isSuccess) {
      return ApiResponseModel.failure('获取产品失败');
    }

    // 查找特定产品
    final product = allProducts.data!.firstWhere(
      (p) => p.id == productId,
      orElse: () => ProductModel(
        id: productId,
        name: '未知产品',
        description: '产品不存在或已下架',
        price: 0,
        stock: 0,
        category: '其他',
        imageUrl: '',
        isPromotion: false,
        ingredients: [],
        preparationTime: 0,
      ),
    );

    // 添加详细描述和规格信息
    final detailedProduct = product.copyWith(
      description:
          product.description +
          '''\n\n详细介绍:\n'''
              '''这款产品采用优质食材制作，口感独特，营养丰富。我们注重食品安全和品质，'''
              '''为您提供健康美味的饮食选择。''',
      specifications: {
        '重量': '约200g',
        '保质期': '24小时',
        '储存方式': '冷藏保存',
        '过敏原信息': product.ingredients.join(', '),
        '产地': '本地生产',
      },
    );

    return ApiResponseModel.success(detailedProduct);
  }

  /// 获取设备列表
  Future<ApiResponseModel<List<DeviceModel>>> getDevices({String? city}) async {
    await _delay();

    // 模拟设备数据
    final devices = [
      DeviceModel(
        id: 'device1',
        name: '中央商务区自动售货机',
        type: 'lunchbox',
        status: 'online',
        location: const DeviceLocation(
          latitude: 39.9042,
          longitude: 116.4074,
          address: '北京市朝阳区建国路88号',
