import 'package:lunchbox/app/data/models/user_model.dart';
import 'package:lunchbox/app/data/models/device_model.dart';
import 'package:lunchbox/app/data/models/product_model.dart';
import 'package:lunchbox/app/data/models/api_response_model.dart';
import 'dart:math';

/// Mock数据提供者
/// 用于在开发环境中提供模拟数据，避免依赖实际的API调用
class MockProvider {
  /// 模拟延迟
  Future<void> _delay([int milliseconds = 500]) async {
    return Future.delayed(Duration(milliseconds: milliseconds));
  }

  /// 模拟登录
  Future<ApiResponseModel<UserModel>> login(Map<String, dynamic> data) async {
    await _delay();

    // 简单的验证逻辑
    final username = data['username'] as String;
    final password = data['password'] as String;

    if (username.isEmpty || password.isEmpty) {
      return ApiResponseModel.failure('用户名和密码不能为空');
    }

    // 返回模拟用户数据
    final user = UserModel(
      id: '1',
      username: username,
      nickname: username,
      avatar: 'https://randomuser.me/api/portraits/men/32.jpg',
      gender: 'male',
      registeredAt: DateTime.now().subtract(const Duration(days: 30)),
      lastLoginAt: DateTime.now(),
      points: 1200,
      memberLevel: 'silver',
      isVerified: true,
      favoriteDevices: ['device1', 'device2'],
    );

    return ApiResponseModel.success(user);
  }

  /// 模拟注册
  Future<ApiResponseModel<UserModel>> register(
    Map<String, dynamic> data,
  ) async {
    await _delay();

    final username = data['username'] as String;
    final password = data['password'] as String;
    final nickname = data['nickname'] as String;

    if (username.isEmpty || password.isEmpty || nickname.isEmpty) {
      return ApiResponseModel.failure('请填写完整的注册信息');
    }

    // 返回注册成功的用户数据
    final user = UserModel(
      id: '${DateTime.now().millisecondsSinceEpoch}',
      username: username,
      nickname: nickname,
      avatar: 'https://randomuser.me/api/portraits/men/32.jpg',
      gender: 'unknown',
      registeredAt: DateTime.now(),
      points: 100,
      memberLevel: 'normal',
      isVerified: false,
      favoriteDevices: [],
    );

    return ApiResponseModel.success(user);
  }

